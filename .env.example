# Copy to .env and fill in. Do not commit .env.

PORT=3000

# Your app URL (no trailing slash). Use https in production.
BASE_URL=http://localhost:3000
# Share embed image URL (og:image). Set in Vercel to production domain e.g. https://absurd-apes.vercel.app so link previews show the logo.
# SITE_URL=https://absurd-apes.vercel.app

# Session secret (change in production)
SESSION_SECRET=your-random-secret-at-least-32-chars

# Discord Developer Portal: https://discord.com/developers/applications
# Create an application → OAuth2 → Redirects: add BASE_URL/api/discord/callback
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Team section: bot token to fetch Discord username/avatar by ID. Same Discord app → Bot → Reset Token → copy here.
DISCORD_BOT_TOKEN=

# Helius (https://dashboard.helius.dev) — for collection supply via DAS getAssetsByGroup
HELIUS_API_KEY=

# Optional: on-chain collection mint addresses for supply + metadata + holders NFT counts (find on Solscan/ME)
# ABSURD_ART_APES_COLLECTION_MINT=
# ABSURD_HORIZONS_COLLECTION_MINT=

# AAA (project) token mint — used for /api/prices, /api/verify, /api/holders, token chart
# AAA_TOKEN_MINT=

# Birdeye (https://birdeye.so) — for 15m OHLC chart in token section (optional)
# BIRDEYE_API_KEY=

# Neon PostgreSQL — Discord logins, wallet linking (Verify), holders Discord names + merge by user, Pairs state. Run: npm run db:migrate
# Use sslmode=verify-full to avoid pg SSL warning (not sslmode=require)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=verify-full
